{
  "name": "oneclicklm",
  "version": "1.0.0",
  "description": "The NotebookLM MCP server that actually works. Auto-healing auth, zero config, one command.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "oneclicklm": "dist/bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "login": "node dist/bin/cli.js login",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "notebooklm",
    "mcp",
    "model-context-protocol",
    "google",
    "ai",
    "claude",
    "cursor"
  ],
  "author": "CRtheHILLS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CRtheHILLS/OneClickLM.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "puppeteer-core": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
